# Optional — only used by /api/cron/refresh (Vercel Cron).
# If unset, the cron route is open (fine for private projects; lock down for production).
# CRON_SECRET=

# OpenF1 (https://openf1.org/auth.html) — in production this app enforces 3 req/s by default.
# Rolling per-minute cap is OFF by default (OPENF1_MAX_RPM=0): strict 30/min can exceed Vercel's
# 60s function limit on heavy pages. Set OPENF1_MAX_RPM=30 for strict anonymous compliance on light traffic.
# `next dev` skips the limiter entirely unless you force it. OPENF1_ACCESS_TOKEN skips the limiter.
# OPENF1_ACCESS_TOKEN=

# OPENF1_MAX_RPS=3
# OPENF1_MAX_RPM=0

# Set to 1 to disable the free-tier limiter (e.g. if your token has different limits).
# OPENF1_RATE_LIMIT_DISABLED=1

# Max parallel logical OpenF1 fetches (each still waits for a rate-limit slot). Default 3.
# OPENF1_MAX_CONCURRENCY=3
