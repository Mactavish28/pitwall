# Optional — only used by /api/cron/refresh (Vercel Cron).
# If unset, the cron route is open (fine for private projects; lock down for production).
# CRON_SECRET=

# OpenF1 (https://openf1.org/auth.html) — free historical data is unauthenticated but
# rate-limited; optional OAuth2 access token raises limits. Never commit real tokens.
# OPENF1_ACCESS_TOKEN=

# Max parallel OpenF1 HTTP calls per snapshot (1–6). Default 2 for unauthenticated use.
# OPENF1_MAX_CONCURRENCY=2
