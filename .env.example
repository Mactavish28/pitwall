# Optional — only used by /api/cron/refresh (Vercel Cron).
# If unset, the cron route is open (fine for private projects; lock down for production).
# CRON_SECRET=

# OpenF1 (https://openf1.org/auth.html) — free tier is unauthenticated; this app enforces
# 3 req/s and 30 req/min before each server-side OpenF1 call unless you set a token below.
# OPENF1_ACCESS_TOKEN=

# Optional overrides (integers). Defaults: 3 RPS, 30 RPM.
# OPENF1_MAX_RPS=3
# OPENF1_MAX_RPM=30

# Set to 1 to disable the free-tier limiter (e.g. if your token has different limits).
# OPENF1_RATE_LIMIT_DISABLED=1

# Max parallel logical OpenF1 fetches (each still waits for a rate-limit slot). Default 3.
# OPENF1_MAX_CONCURRENCY=3
